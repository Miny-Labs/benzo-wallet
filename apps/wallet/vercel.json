{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm install && pnpm -r build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://api.benzo.space/:path*" },
    { "source": "/circuits/:path*", "destination": "https://api.benzo.space/circuits/:path*" },
    { "source": "/((?!api/|assets/|circuits/).*)", "destination": "/index.html" }
  ]
}
