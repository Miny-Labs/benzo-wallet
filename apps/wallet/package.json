{
  "name": "@benzo/wallet-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Benzo consumer wallet - private USDC, web2 feel (Cash App for money you control).",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit -p tsconfig.json && vite build",
    "preview": "vite preview --port 5175",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --maxWorkers=1 --minWorkers=1",
    "stage:circuits": "node scripts/stage-circuits.mjs",
    "check:circuits": "node scripts/check-circuits.mjs"
  },
  "dependencies": {
    "@avalabs/eerc-sdk": "^1.0.2",
    "@benzo/config": "workspace:*",
    "@benzo/core": "workspace:*",
    "@benzo/links": "workspace:*",
    "@benzo/types": "workspace:*",
    "@benzo/ui": "workspace:*",
    "@benzo/wallet": "workspace:*",
    "@tanstack/react-query": "^5.59.0",
    "framer-motion": "^11.3.0",
    "lucide-react": "^0.408.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6.26.0",
    "viem": "^2.21.0",
    "wagmi": "^2.12.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "jsdom": "^24.1.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
