# The browser calls the backend same-origin at /api/*. In production that path is
# proxied to the Cloud Run backend by the "rewrites" block in vercel.json (the
# destination is hard-coded there — Vercel rewrites can't read env vars). No
# BENZO_API_URL is needed anymore; the old serverless proxy that read it is gone.
# For local dev, vite.config proxies /api to http://localhost:8791 (see server.proxy).

# Chain selection. Use one of these aliases; VITE_CHAIN_ENV takes precedence.
VITE_CHAIN_ENV=fuji
# VITE_BENZO_NETWORK=fuji

# RPC configuration. VITE_RPC_URL is the shared fallback; chain-specific values win.
VITE_FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
# VITE_BENZONET_RPC_URL=https://rpc.benzo.space/wallet/<token>
# VITE_RPC_URL=

# Leave VITE_API_BASE_URL unset so the browser uses the same-origin /api proxy.
# VITE_API_BASE_URL=

# Optional overrides. These default from @benzo/config.
# VITE_EERC_ENCRYPTED_ERC_ADDRESS=
# VITE_EERC_REGISTRAR_ADDRESS=
# VITE_USDC_TOKEN_ADDRESS=
# VITE_HANDLE_REGISTRY_ADDRESS=
